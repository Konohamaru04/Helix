{
  "name": "helix-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Helix is a local-first desktop AI workbench by Abstergo, built with Electron, React, SQLite, and a managed Python inference server.",
  "author": "Abstergo",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package:dir_win": "npm run build && electron-builder --config electron-builder.yml --win dir",
    "package:win": "npm run build && electron-builder --config electron-builder.yml",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:python": ".\\python_embeded\\python.exe -m pytest",
    "dev:tui": "vite --config tui.vite.config.ts build --watch & sleep 2 && node dist/tui/main.js",
    "tui": "vite --config tui.vite.config.ts build && node dist/tui/main.js",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run test:python && npm run build"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "markdown-it": "^14.1.1",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/blessed": "^0.1.27",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.3"
  }
}
