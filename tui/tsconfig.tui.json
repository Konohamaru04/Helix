{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["node", "blessed", "vitest/globals"],
    "outDir": "../dist/tui",
    "rootDir": "..",
    "paths": {
      "@tui/*": ["tui/*"],
      "@bridge/*": ["bridge/*"]
    }
  },
  "include": [
    "tui/**/*.ts",
    "../bridge/**/*.d.ts",
    "../bridge/**/*.ts"
  ]
}